# Paste your Stripe test keys below:
# STRIPE_SECRET_KEY=<paste your Stripe Secret Key here>
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<paste your Stripe Publishable Key here>
# STRIPE_WEBHOOK_SECRET=<paste your Stripe webhook secret (whsec_...) here>

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# Auth/session security (required)
AUTH_SECRET=

# Admin bootstrap (set once to create first admin via /api/auth/bootstrap-admin)
ADMIN_BOOTSTRAP_TOKEN=

# Gmail/Nodemailer email setup
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=
